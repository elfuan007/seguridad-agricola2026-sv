window.detectId = {
  didRegistrationWithUrl: function(success, fail, url) {
    app.detectId.didRegistrationWithUrl(success, fail, url);
  },
  didRegistrationWithQRCode: function(success, fail, url, code) {
    app.detectId.didRegistrationWithQRCode(success, fail, url, code);
  },
  getDeviceId: function(success, fail) {
    app.detectId.getDeviceId(success, fail);
  },
  didInit: function(success, fail) {
    app.detectId.didInit(success, fail);
  },
  getAccounts: function(success) {
    app.detectId.getAccounts(success);
  },
  setAccountUsername: function(success, fail, username, account) {
    app.detectId.setAccountUsername(success, fail, username, account);
  },
  removeAccount: function(success, fail, account) {
    app.detectId.removeAccount(success, fail, account);
  },
  getTokenValue: function(success, fail, account) {
    app.detectId.getTokenValue(success, fail, account);
  },
  getTokenTimeStepValue: function(success, fail, account) {
    app.detectId.getTokenTimeStepValue(success, fail, account);
  },
  removeAllAccounts: function() {
    return new Promise(async (resolve, reject) => {
      await app.detectId.getAccounts(async (accounts) => {
        if (accounts && accounts.length) {
          await accounts.forEach(async (account) => {
            await app.detectId.removeAccount(
              () => {},
              (err) => {
                reject(err);
              },
              account
            );
          });
        }
      });
      resolve();
    });
  },
  updateDeviceInformation: function(succes, fail) {
    app.detectId.updateDeviceInformation(succes, fail);
  },
};

