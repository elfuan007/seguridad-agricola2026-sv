// Indica si es una app cordova
window.isMobileApp = function() {
  return typeof window.cordova !== "undefined";
};

// Oculta el splash screen
window.common = {
  hideSplashScreen: function() {
    if (window.isMobileApp()) {
      app.hideSplashScreen();
    }
  },

  getInfo: function() {
    if (window.isMobileApp()) {
      var info = Object.assign({}, app.getDeviceInfo());
      info.uuid = app.getDeviceUUID();
      return info;
    } else {
      return {};
    }
  },

  getUUID: function() {
    if (window.isMobileApp()) {
      return app.getDeviceUUID();
    } else {
      return null;
    }
  },

  iosPlatform: function() {
    if (window.isMobileApp()) {
      return app.iosPlatform();
    } else {
      return false;
    }
  },

  androidPlatform: function() {
    if (window.isMobileApp()) {
      return app.androidPlatform();
    } else {
      return false;
    }
  },

  //abre un link externo
  openLink: function(url, target, options) {
    if (!target) {
      target = "_system";
    }
    var ref = null;
    if (window.isMobileApp()) {
      ref = app.openLink(url, target, options);
      return ref;
    } else {
      ref = window.open(url, target);
      return ref;
    }
  },

  openPDFFile: function(data, name) {
    if (window.isMobileApp()) {
      return app.openPDFFile(data, name);
    } else {
      return this.downloadFileWEB(data, name);
    }
  },

  downloadFileWEB: function(data, name) {
    let fileURL = window.URL.createObjectURL(data);
    let tempLink = document.createElement("a");
    tempLink.setAttribute("type", "hidden");
    tempLink.href = fileURL;
    tempLink.download = name || "archivo.txt";
    document.body.appendChild(tempLink);
    tempLink.click();
    tempLink.remove();
  },
  downloadFile: function(
    fileData,
    fileName,
    directoryName,
    subdiretoryName,
    onSuccess,
    onError
  ) {
    if (window.cordova && app) {
      app.downloadFile(
        fileData,
        fileName,
        directoryName,
        subdiretoryName,
        onSuccess,
        onError
      );
    }
  },

  downloadFileIphone: function(fileData, onSuccess, onError) {
    if (window.cordova && app) {
      app.downloadFileIphone(fileData, onSuccess, onError);
    }
  },
  saveBase64ToPNGAndroid: function(
    fileData,
    directoryName,
    fileName,
    onSuccess,
    onError
  ) {
    if (window.cordova && app) {
      app.saveBase64ToPNGAndroid(
        fileData,
        directoryName,
        fileName,
        onSuccess,
        onError
      );
    }
  },
};

window.camera = {
  // Lector de codigo de barras
  onBarcodeScanner: function(onSuccess, onError, prompt) {
    if (window.cordova && app) {
      app.onBarcodeScanner(onSuccess, onError, prompt);
    }
  },
};

window.security = {
  // Verificador de huellas digitales
  isFingerprintEnabled: function() {
    if (window.isMobileApp()) {
      return new Promise(function(resolve, reject) {
        app.isFingerprintEnabled(function(enabled) {
          resolve(enabled);
        });
      });
    } else {
      return new Promise(function(resolve) {
        setTimeout(function() {
          resolve(false);
        });
      });
    }
  },

  // Verificador de huellas digitales
  verifyFingerprint: function(data) {
    if (window.isMobileApp()) {
      return new Promise(function(resolve, reject) {
        app.verifyFingerprint(
          data,
          function() {
            resolve();
          },
          function(error) {
            reject(error);
          }
        );
      });
    } else {
      return new Promise(function(resolve, reject) {
        setTimeout(function() {
          reject(1);
        });
      });
    }
  },

  // Guarda datos sensibles
  storeValue: function(key, value) {
    if (window.isMobileApp()) {
      return new Promise(function(resolve, reject) {
        app.setSecureValue(
          key,
          value,
          function() {
            resolve(true);
          },
          function(error) {
            reject(error);
          }
        );
      });
    } else {
      return new Promise(function(resolve) {
        setTimeout(function() {
          resolve(true);
        });
      });
    }
  },

  //devuelve si el SS está disponible o no
  getSecureStorageStatus: function() {
    return app.getSecureStorageStatus();
  },

  // Obtiene datos sensibles
  retrieveValue: function(key) {
    if (window.isMobileApp()) {
      return new Promise(function(resolve, reject) {
        app.getSecureValue(
          key,
          function(value) {
            resolve(value);
          },
          function(error) {
            reject(error);
          }
        );
      });
    } else {
      return new Promise(function(resolve) {
        setTimeout(function() {
          resolve("");
        });
      });
    }
  },

  // Elimina datos sensibles
  removeValue: function(key) {
    if (window.isMobileApp()) {
      return new Promise(function(resolve, reject) {
        app.removeSecureValue(
          key,
          function(value) {
            resolve(true);
          },
          function(error) {
            reject(error);
          }
        );
      });
    } else {
      return new Promise(function(resolve) {
        setTimeout(function() {
          resolve(true);
        });
      });
    }
  },
};

