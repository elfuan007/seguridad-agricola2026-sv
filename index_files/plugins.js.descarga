window.onboarding = {
  initialize: function(
    licenseID, 
    baseURL,
    checkDocumentLightness,
    checkDocumentPosition,
    checkDocumentSparkles,
    falsePositive,
    checkFacialLightness,
    checkFacialPosition,
    checkFacialMask,
    checkFacialFocus) {
    if (window.isMobileApp()) {
      return new Promise(function(resolve, reject) {
        app.onboarding.initialize(
          licenseID, 
          baseURL, 
          checkDocumentLightness,
          checkDocumentPosition,
          checkDocumentSparkles,
          falsePositive,
          checkFacialLightness,
          checkFacialPosition,
          checkFacialMask,
          checkFacialFocus,
          resolve, reject);
      });
    } else {
      return new Promise(function(resolve, reject) {
        setTimeout(function() {
          reject("Unable to execute plugin in a non-app environment");
        });
      });
    }
  },
  setFixedMode: function() {
    if (window.isMobileApp()) {
      return new Promise(function(resolve, reject) {
        app.onboarding.setFixedMode(resolve, reject);
      });
    } else {
      return new Promise(function(resolve, reject) {
        setTimeout(function() {
          reject("Unable to execute plugin in a non-app environment");
        });
      });
    }
  },
  startScanDocument: function(
    documentType,
    scanDocumentImageCallback,
    scanDocumentDataCallback,
    pdf417Callback,
    pdf417Timeout
  ) {
    if (window.isMobileApp()) {
      return new Promise(function(resolve, reject) {
        app.onboarding.startScanDocument(
          documentType,
          scanDocumentImageCallback,
          scanDocumentDataCallback,
          pdf417Callback,
          pdf417Timeout,
          resolve,
          reject
        );
      });
    } else {
      return new Promise(function(resolve, reject) {
        setTimeout(function() {
          reject("Unable to execute plugin in a non-app environment");
        });
      });
    }
  },

  scanDocumentForSide: function(side, scanID) {
    return new Promise(function(resolve, reject) {
      app.onboarding.scanDocumentForSide(side, scanID, resolve, reject);
    });
  },

  validateFace: function(scanID, faceAcquisitorCallback) {
    return new Promise(function(resolve, reject) {
      app.onboarding.validateFace(
        scanID,
        faceAcquisitorCallback,
        resolve,
        reject
      );
    });
  },
  detectFace: function(faceValidationMode, faceAcquisitorCallback, onSuccess, onError) {
    try {
      app.onboarding.detectFace(
        faceValidationMode,
        faceAcquisitorCallback,
        onSuccess,
        onError
      );
    } catch (e) {
      console.error('❌ [RNPN] Error en window.onboarding.detectFace:', e);
      if (onError) onError(e);
    }
  },
};

