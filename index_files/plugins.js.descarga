window.medallia = {
  setup: function(tokenAndroid, tokeniOS) {
    if (window.isMobileApp()) {
      app.setupMedallia(tokenAndroid, tokeniOS);
    }
  },
  showForm: function(formId) {
    if (window.isMobileApp()) {
      app.showFormMedallia(formId);
    }
  },
  setCustomParameters: function(data) {
    if (window.isMobileApp()) {
      app.setCustomParametersMedallia(data);
    }
  },
  setCustomParameter: function(key, value) {
    if (window.isMobileApp()) {
      app.setCustomParameterMedallia(key, value);
    }
  },
  onEventMedallia: function(data, delay = 1000) {
    return new Promise(function(resolve) {
      if (window.isMobileApp()) {
        app.onEventMedallia(resolve, delay);
        app.setCustomParametersMedallia(data);
      } else {
        resolve();
      }
    });
  },
};

